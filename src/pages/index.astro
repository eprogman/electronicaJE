---
import Layout from "../layouts/Layout.astro";
import CardServicios from "../components/CardServicios.astro";
import Expandiblesection from "../components/Expandiblesection.astro";

import preguntasfrecuentes from "../config/preguntasfrecuentes.json";

import circuit from "../assets/images/circuit.jpeg";
import brazo from "../assets/images/brazo.jpg";
import io from "../assets/images/io.png";
import dash from "../assets/images/dash.png";
import onoff from "../assets/images/onoff.png";
import alerta from "../assets/images/alerta.png";

---

<Layout title="Prototipos, diseño y desarrollo de soluciones electrónicas." description="Proyectos electrónicos variados, desde sistemas de control hasta prototipos con microcontroladores PIC.">
	<!-- SECCION 1 -->
	<section
		class="relative my-9 min-h-96 flex justify-center mx-auto items-center lg:w-5/6 bg-[url('/images/flyb2.jpeg')] bg-cover bg-center rounded-2xl"
	>
		<div class="absolute inset-0 bg-black/50 rounded-2xl"></div>
		<div class="flex flex-col gap-y-10 w-3/4 items-center text-white">
			<span class="bg-black/50 px-3 py-1 rounded-lg backdrop-blur-sm">
			<h1	
				class="text-3xl sm:text-4xl lg:text-5xl ml-3 sm:pl-0 font-semibold tracking-tight text-center"
			>
				<span
					class="bg-gradient-to-r from-red-400 via-orange-500 to-blue-500 text-transparent bg-clip-text"
					>Ideas que se convierten en electrónica</span
				>
			</h1>
			<p class="text-lg text-gray-200 mt-4 ml-3 font-semibold">
				Prototipos, diseño y desarrollo de soluciones electrónicas.
			</p>
			</span>
			<p
				class="text-base sm:text-lg lg:text-xl text-white text-center max-w-2xl drop-shadow-md leading-relaxed tracking-tight"
			>
				Si estas de acuerdo con nuestra
				<a href="/notaPrivacidad" class="underline text-teal-300 hover:text-teal-200 font-semibold"
					>política de Privacidad</a
				>
				y con los
				<a href="/terminos" class="underline text-teal-300 hover:text-teal-200 font-semibold"
					>términos y condiciones</a
				>, coméntanos qué tipo de proyecto electrónico requieres
				enviando un correo electrónico.
			</p>
		</div>

	</section>

	<!-- SECCION 2 -->
	<section class="mt-7 mx-auto flex flex-col w-5/6 lg:w-full">
		<div class="grid xl:w-4/5 sm:grid-cols-3 lg:gap-10 xl:m-auto">
			<CardServicios
				title={"Proyectos electrónicos con brazos robóticos"}
				description={"Implementación de brazos robóticos con microcontroladores PIC, conectados y controlados mediante puerto serial."}
				image={brazo}
			/>
			<CardServicios
				title={"Proyectos electrónicos con circuitos analógicos"}
				description={"Diseño e implementación de proyectos con circuitos y componentes analógicos para aplicaciones educativas y experimentales."}
				image={circuit}
			/>
			<CardServicios
				title={"Proyectos IoT con PIC + Node.js"}
				description={"Sensores conectados al microcontrolador, datos mostrados en tiempo real en tu website mediante Node.js y Socket.io."}
				image={io}
			/>
			<CardServicios
				title={"Control remoto de proyectos electrónicos"}
				description={"Encender/apagar dispositivos vía Node.js desde la web, utilizando microcontroladores PIC para controlar proyectos electrónicos de forma remota."}
				image={onoff}
			/>
			<CardServicios
				title={"Alertas y notificaciones en proyectos electrónicos"}
				description={"Implementación de un sistema de monitoreo con microcontroladores PIC y Node.js, capaz de procesar datos seriales en intervalos cortos, generar alertas en tiempo real cuando se superan umbrales definidos y enviar resúmenes periódicos a tu dispositivo móvil."}
				image={alerta}
			/>
		    <CardServicios
				title={"Dashboard IoT"}
				description={"Desarrollo de dashboards web interactivos para IoT, listos para conectarse a cualquier microcontrolador o sistema de backend. Incluyen visualización de datos en tiempo real, control de actuadores y gráficos interactivos, con soporte para integración mediante APIs."}
				image={dash}
			/>
		</div>
	</section>

	<!-- SECCION 3 PREGUNTAS-->

	<section class="flex mt-20 mx-auto w-5/6 justify-around lg:w-full">
		<div class="hidden xl:block xl:w-2/5 pl-28 my-auto">
			<h1 class="text-4xl w-1/2 font-semibold">Preguntas frecuentes</h1>
		</div>
		<div class="flex flex-col w-full xl:w-3/5 px-3 gap-3 mb-3">
			{
				preguntasfrecuentes.map((pregunta) => (
					<Expandiblesection
						title={pregunta.title}
						description={pregunta.description}
					/>
				))
			}
		</div>
	</section>

	<!-- SECCION 4 PREGUNTAS-->
	<section id="contacto" class="w-full min-h-screen bg-gradient-to-b from-gray-50 to-gray-200 flex items-center justify-center p-6">
		<div class="w-full max-w-3xl h-[85vh] bg-white rounded-2xl shadow-2xl overflow-hidden">
		<iframe 
			src="https://formulario2026jye.netlify.app/?tokenn=IFR12AM3"
			class="w-full h-full border-0">
		</iframe>
		</div>
	</section>


</Layout>
