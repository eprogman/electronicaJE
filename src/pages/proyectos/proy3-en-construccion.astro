---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Proyecto: 3">
    <h1 class="text-4xl font-bold text-gray-800">🚧 Página en construcción</h1>
    <p class="mt-4 text-gray-600">Pronto estará disponible. Gracias por tu paciencia.</p>
    <a href="/" class="mt-6 inline-block text-blue-600 underline">Volver al inicio</a>
</Layout>


<style>
	.project-page {
		min-height: calc(100vh - 180px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem 1rem;
	}

	.project-content {
		max-width: 48rem; /* ~max-w-4xl */
		width: 100%;
		padding: 2rem 1rem;
		color: #e5e7eb; /* text-slate-200 */
	}

	.project-content p {
		margin-bottom: 1.5rem;
	}
</style>
