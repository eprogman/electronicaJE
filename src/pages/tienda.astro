---
import ProductList from "../components/ProductList.astro";
import Cart from "../components/Cart.jsx";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Tienda de componentes electrónicos en Perú | Proyectos electrónicos" description="Compra componentes electrónicos y accesorios para proyectos: sensores, módulos, y más en Perú.">
    <body class="bg-gray-50 font-sans text-gray-800 leading-relaxed">
        <header
            class="bg-gradient-to-r from-[rgba(29,141,126,0.5)] to-[rgba(31,41,55,0.5)] text-white py-12 text-center"
        >
            <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">
                Accesorios para proyectos electrónicos
            </h1>
            <p
                class="mt-3 text-base md:text-lg max-w-prose mx-auto text-gray-200"
            >
                Encuentra componentes para tus proyectos electrónicos: : desde componentes básicos hasta módulos para prototipos, robótica y desarrollo.
            </p>
            <h2>¿Para quién es esta tienda?</h2>
            <ul>
                <li>Estudiantes de electrónica</li>
                <li>Desarrolladores</li>
                <li>Proyectos escolares y universitarios</li>
                <li>Automatización y domótica</li>
            </ul>
        </header>

        <main
            class="container mx-auto px-4 md:flex md:gap-8 flex-col md:flex-row py-10"
        >
            <div class="w-full md:w-2/3">
                <ProductList />
            </div>
            <aside class="w-full md:w-1/3">
                <Cart client:load />
            </aside>
        </main>
    </body>
</Layout>
