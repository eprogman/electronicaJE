---
import ProductList from "../components/ProductList.astro";
import Cart from "../components/Cart.jsx";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Productos">
    <body class="bg-gray-50">
        <header
            class="bg-gradient-to-r from-blue-600 to-blue-500 text-white py-8 text-center font-bold"
        >
            <h1 class="text-2xl md:text-3xl">Tienda Electrónica</h1>
            <p class="mt-2 text-sm md:text-base">
                Componentes y módulos para tus proyectos
            </p>
        </header>

        <main
            class="container mx-auto px-4 md:flex md:gap-6 flex-col md:flex-row py-8"
        >
            <div class="w-full md:w-2/3">
                <ProductList />
            </div>
            <aside class="w-full md:w-1/3">
                <Cart client:load />
            </aside>
        </main>
    </body>
</Layout>
