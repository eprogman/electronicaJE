---
const { title, description } = Astro.props;
---

<div class="expandable border rounded-lg shadow p-3">
    <!-- Encabezado (Texto + Botones) -->
    <div class="flex justify-between items-center">
        <p class="font-bold text-emerald-950">{title}</p>

        <!-- Botón Mostrar -->
        <button class="btnShow p-2 rounded-full hover:bg-gray-200 transition">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-plus"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M12 5l0 14"></path><path d="M5 12l14 0"></path></svg
            >
        </button>

        <!-- Botón Ocultar -->
        <button
            class="btnHide hidden p-2 rounded-full hover:bg-gray-200 transition"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-minus"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M5 12l14 0"></path></svg
            >
        </button>
    </div>

    <!-- Texto adicional oculto -->
    <div
        class="extra overflow-hidden max-h-0 transition-all duration-500 ease-in-out"
    >
        <p class="mt-2 text-gray-800 font-semibold">{description}</p>
    </div>

    <!-- Script interno para manejar animación -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll(".expandable").forEach((row) => {
                const btnShow = row.querySelector(".btnShow");
                const btnHide = row.querySelector(".btnHide");
                const extra = row.querySelector(".extra") as HTMLElement;

                btnShow?.addEventListener("click", () => {
                    extra.style.maxHeight = extra.scrollHeight + "px";
                    btnShow.classList.add("hidden");
                    btnHide?.classList.remove("hidden");
                });

                btnHide?.addEventListener("click", () => {
                    extra.style.maxHeight = "0";
                    btnHide.classList.add("hidden");
                    btnShow?.classList.remove("hidden");
                });
            });
        });
    </script>
</div>

<style>
    h2 {
        font-size: 1em;
        width: 60%;
    }
    p {
        font-size: 0.8em;
        width: 100%;
        text-align: left;
        padding: 0 10px;
        text-justify: auto;
    }
    button {
        border-radius: 50%;
        border: none;
        background: conic-gradient(at bottom right, #000000, #150050, #3f0071);
        color: #f5f5f5;
        font-weight: bold;
        cursor: pointer;
        padding: 7px;
        border: 1px solid white;
    }

    .icon_inactive {
        display: none;
    }
    .icon_active {
        display: block;
    }
</style>
