---
const { title, description, image } = Astro.props;
---

<article
    class="bg-white/30 border border-gray-200 rounded-lg shadow hover:shadow-lg transition-shadow duration-300 w-full mb-4"
>
    <div class="p-4 flex flex-col items-center text-center h-full">
        <div class="w-full h-72 overflow-hidden rounded-md bg-gray-100">
            <img
                src={image.src}
                alt={title}
                class="w-full h-full object-cover"
                loading="lazy"
            />
        </div>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">{title}</h3>
        <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
    </div>
</article>
