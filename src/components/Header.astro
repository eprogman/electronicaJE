---
import logo from "../assets/images/logo.jpeg";
---

<header
    class="sticky top-0 right-0 left-0 z-20 bg-gradient-to-r from-slate-900 via-slate-800 to-teal-700/90 shadow-md backdrop-blur-sm"
>
    <div
        class="max-w-5xl mx-auto flex flex-wrap items-center justify-between gap-6 px-4 py-4"
    >
        <!-- Logo -->
        <a href="/" class="text-white text-xl font-bold mb-3 sm:mb-0">
            <img
                class="h-14 w-14 sm:h-24 sm:w-24 rounded-4xl m-auto"
                src={logo.src}
                alt="Logo"
            /></a
        >

        <!-- Links -->
        <div class="flex flex-wrap items-center gap-6 contact">
            <a
                href="/"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Inicio</a
            >
            <a
                href="/productos"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Productos</a
            >
            <a
                href="/acerca"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Acerca</a
            >
            <a
                href="/tienda"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Componentes Electrónicos</a
            >
            <a
                href="mailto:contacto.negocio@gmail.com"
                class="text-sm sm:text-base md:text-lg email-link"
                title="Enviar correo"
            >
                <!-- Ícono de correo SVG -->
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="40"
                    height="40"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="icon icon-tabler icons-tabler-filled icon-tabler-mail icono"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                    ></path><path
                        d="M22 7.535v9.465a3 3 0 0 1 -2.824 2.995l-.176 .005h-14a3 3 0 0 1 -2.995 -2.824l-.005 -.176v-9.465l9.445 6.297l.116 .066a1 1 0 0 0 .878 0l.116 -.066l9.445 -6.297z"
                    ></path><path
                        d="M19 4c1.08 0 2.027 .57 2.555 1.427l-9.555 6.37l-9.555 -6.37a2.999 2.999 0 0 1 2.354 -1.42l.201 -.007h14z"
                    ></path></svg
                >
                <span>contacto.negocio@gmail.com</span>
            </a>
        </div>
    </div>
</header>

<style>
    .email-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #38b2ac; /* turquesa suave */
        font-size: 1rem;
        text-decoration: none;
    }

    .email-link:hover {
        color: #2c7a7b; /* turquesa un poco más oscuro */
        text-decoration: underline;
    }
    .icono {
        transition: transform 0.2s ease;
    }

    .email-link:hover .icono {
        transform: scale(1.1);
    }
</style>
