---
import logo from "../assets/images/logo.jpeg";
---

<header
    class="sticky top-0 right-0 left-0 z-20 bg-gradient-to-r from-slate-900 via-slate-800 to-teal-700/90 shadow-md backdrop-blur-sm"
>
    <div
        class="max-w-5xl mx-auto flex flex-wrap items-center justify-between gap-6 px-4 py-4"
    >
        <!-- Logo -->
        <a href="/" class="text-white text-xl font-bold mb-3 sm:mb-0">
            <img
                class="h-14 w-14 sm:h-24 sm:w-24 rounded-4xl m-auto"
                src={logo.src}
                alt="Logo"
            /></a
        >

        <!-- Links -->
        <div class="flex flex-wrap items-center gap-6 contact">
            <a
                href="/"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Inicio</a
            >
            <a
                href="/productos"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Productos</a
            >
            <a
                href="/acerca"
                class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                >Acerca</a
            >
            <a
                    href="/tienda"
                    class="text-slate-100 text-sm sm:text-base md:text-lg hover:text-teal-200 transition-colors"
                    >Componentes Electrónicos</a
                >
            <a href="/#contacto" class="flex items-center gap-2 text-gray-100 hover:text-teal-200" >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
            <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-8.4 8.4a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32l8.4-8.4Z" />
            <path d="M5.25 5.25a3 3 0 0 0-3 3v10.5a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3V13.5a.75.75 0 0 0-1.5 0v5.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5V8.25a1.5 1.5 0 0 1 1.5-1.5h5.25a.75.75 0 0 0 0-1.5H5.25Z" />
            </svg>
            Contacto
        </a>
        </div>
    </div>
</header>

<style>
    .email-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #38b2ac; /* turquesa suave */
        font-size: 1rem;
        text-decoration: none;
    }

    .email-link:hover {
        color: #2c7a7b; /* turquesa un poco más oscuro */
        text-decoration: underline;
    }
    .icono {
        transition: transform 0.2s ease;
    }

    .email-link:hover .icono {
        transform: scale(1.1);
    }
</style>
